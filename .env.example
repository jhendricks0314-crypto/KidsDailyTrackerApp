# Copy this file to ".env" for local development with `netlify dev`.
# In production, set these in the Netlify dashboard instead
# (Site configuration -> Environment variables). NEVER commit your real values.

# Required: your Anthropic API key (starts with sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# (Login tokens are signed automatically from ANTHROPIC_API_KEY — no separate
# session secret is required. You may optionally set SESSION_SECRET to your own
# long random string if you prefer to manage signing independently.)

# Optional: override the grading model. Defaults to claude-sonnet-4-6.
# A cheaper option for simple grading is claude-haiku-4-5-20251001.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: protect the one-time admin setup. If set, initializing the admin
# account requires this exact key (entered on the first-run setup screen).
# Leave it unset for an open first-run setup (just open the app first yourself).
# ADMIN_SETUP_KEY=some-long-random-setup-key

# ---------------------------------------------------------------------------
# Email (account verification + the 8 PM Central daily report).
# These power the verification email at signup and the nightly progress email.
# Without them, the app still works but those emails simply won't send.
#
# Sign up at https://resend.com, verify your sending domain, create an API key.
RESEND_API_KEY=re_your_resend_api_key
# The "from" address (must be on your Resend-verified domain):
FROM_EMAIL=StudyQuest <no-reply@yourdomain.com>
# Your app's public URL, used to build links inside emails:
APP_URL=https://your-site.netlify.app

# Optional (LOCAL DEV ONLY): also return the verification link in the signup
# API response so you can test without a real inbox. NEVER set in production.
# ALLOW_DEV_VERIFY_LINK=1

# ---------------------------------------------------------------------------
# Rate limits for the AI endpoints (per FAMILY, shared across parents + the
# kids' link). These cap Anthropic API usage / abuse. Defaults shown; override
# only if you want different ceilings. Format: integers.
# RL_GRADE_PER_MIN=20
# RL_GRADE_PER_DAY=400
# RL_GENERATE_PER_MIN=10
# RL_GENERATE_PER_DAY=150
# RL_HELP_PER_MIN=15
# RL_HELP_PER_DAY=250

# ---------------------------------------------------------------------------
# Event logging (admin troubleshooting). Optional.
# Which levels to PERSIST (most->least severe: error, warn, info, verbose,
# debug). A level includes all more-severe levels. Default: info.
# Use "debug" or "verbose" temporarily when troubleshooting, then revert —
# verbose logs every request and uses more storage.
# LOG_LEVEL=info
# How long log entries are kept conceptually (used by the day-bucket cleanup
# you trigger from the admin Logs screen). Default: 30.
# LOG_RETENTION_DAYS=30
